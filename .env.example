# Скопируй в .env и подставь свои значения. Файл .env в git не коммитится.

# PostgreSQL (совпадает с docker-compose: сервис db)
POSTGRES_USER=msghub
POSTGRES_PASSWORD=changeme
DB_NAME=msghub

# Async SQLAlchemy: в Docker хост БД — имя сервиса `db`, не localhost
DATABASE_URL=postgresql+asyncpg://msghub:changeme@db:5432/msghub

# Redis: в Docker хост — имя сервиса `redis`
REDIS_URL=redis://redis:6379/0

# JWT (SECRET_KEY может сгенерироваться при первом запуске, если пусто)
# SECRET_KEY=

# CORS: origin фронтенда (несколько через запятую)
ALLOWED_ORIGINS=http://localhost:5173

# Опционально: уровень логов, лимиты — см. app/backend/config.py
# LOG_LEVEL=INFO
